{
  "name": "cross-csl",
  "private": true,
  "packageManager": "npm@10.9.7",
  "engines": {
    "node": ">=22",
    "npm": ">=10"
  },
  "scripts": {
    "test": "npm run test:ci",
    "clean": "npm run clean --workspaces --if-present",
    "build": "npm run build:core && npm run build:nodejs && npm run build:browser && npm run build:mobile",
    "build:core": "npm run build --workspace packages/cross-csl-core",
    "build:nodejs": "npm run build --workspace packages/cross-csl-nodejs",
    "build:browser": "npm run build --workspace packages/cross-csl-browser",
    "build:mobile": "npm run build --workspace packages/cross-csl-mobile",
    "test:ci": "npm run build:core && npm run build:nodejs && npm run test:nodejs && npm run typecheck:browser && npm run test:browser && npm run build:browser && npm run build:mobile",
    "test:nodejs": "npm test --workspace packages/cross-csl-nodejs",
    "typecheck:browser": "npm run typecheck --workspace packages/cross-csl-browser",
    "test:browser": "npm run test:ci --workspace packages/cross-csl-browser",
    "format": "prettier --config .prettierrc packages/**/*.ts --write",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix"
  },
  "dependencies": {
    "bech32": "^2.0.0",
    "bignumber.js": "^9.0.1",
    "yargs": "^17.2.1"
  },
  "workspaces": [
    "packages/*"
  ],
  "devDependencies": {
    "@types/node": "^16.9.1",
    "@types/sinon": "10.0.2",
    "@types/yargs": "^17.0.5",
    "@typescript-eslint/eslint-plugin": "^5.6.0",
    "@typescript-eslint/parser": "^5.6.0",
    "chai": "^4.3.4",
    "eslint": "^8.4.1",
    "flowgen": "^1.14.1",
    "glob": "^7.2.0",
    "prettier": "^2.4.1",
    "ts-node": "^10.2.1",
    "typescript": "^4.4.3"
  }
}
