{
  "name": "@emurgo/cross-csl-mobile",
  "version": "8.0.0",
  "description": "",
  "main": "dist/index.js",
  "files": [
    "dist/**"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "clean": "rm -rf ./dist",
    "gen-flow-defs": "node ../../generate-flow.js",
    "rebuild": "npm run clean && npm run build && npm run gen-flow-defs",
    "pack-tar:dry": "npm run rebuild && npm pack --dry-run",
    "pack-tar": "npm run rebuild && npm pack",
    "publish:beta": "npm publish --tag beta --access public",
    "publish:prod": "npm publish --access public",
    "release": "npm run rebuild && npm publish --scope=emurgo --access public"
  },
  "author": "EMURGO",
  "license": "MIT",
  "dependencies": {
    "@emurgo/cross-csl-core": "8.0.0"
  },
  "peerDependencies": {
    "@emurgo/csl-mobile-bridge-jsi": "1.0.0-alpha.7"
  },
  "devDependencies": {
    "install-peers-cli": "^2.2.0",
    "typescript": "^4.4.4",
    "@types/ws": "8.5.4"
  }
}
