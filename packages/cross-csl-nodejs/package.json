{
  "name": "@emurgo/cross-csl-nodejs",
  "version": "8.0.0",
  "description": "",
  "main": "dist/index.js",
  "scripts": {
    "test": "env TS_NODE_TRANSPILE_ONLY=true TS_NODE_COMPILER_OPTIONS='{\"module\":\"commonjs\"}' mocha -r ts-node/register 'spec/**/*.ts'",
    "test:watch": "mocha --watch",
    "build": "tsc --project tsconfig.json",
    "clean": "rm -rf ./dist",
    "gen-flow-defs": "node ../../generate-flow.js",
    "rebuild": "npm --prefix ../.. run build:core && npm run clean && npm run build && npm run gen-flow-defs",
    "pack-tar:dry": "npm run rebuild && npm pack --dry-run",
    "pack-tar": "npm run rebuild && npm pack",
    "publish:beta": "npm publish --tag beta --access public",
    "publish:prod": "npm publish --access public",
    "release": "npm run rebuild && npm publish --scope=emurgo --access public"
  },
  "files": [
    "dist/**"
  ],
  "author": "EMURGO",
  "license": "MIT",
  "dependencies": {
    "@emurgo/cross-csl-core": "8.0.0",
    "@emurgo/cardano-serialization-lib-nodejs": "14.1.2"
  },
  "devDependencies": {
    "@types/mocha": "^9.1.1",
    "@types/node": "^16.11.56",
    "chai": "^4.3.4",
    "mocha": "^9.1.2",
    "ts-node": "^10.2.1",
    "typescript": "^4.4.3"
  }
}
