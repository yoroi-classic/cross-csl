{
  "name": "@emurgo/cross-csl-core",
  "version": "8.0.0",
  "description": "",
  "main": "dist/index.js",
  "files": [
    "dist/**"
  ],
  "scripts": {
    "test": "env TS_NODE_COMPILER_OPTIONS='{\"module\": \"commonjs\" }' mocha -r ts-node/register 'tests/**/*.ts'",
    "test:watch": "mocha --watch",
    "build": "tsc --project tsconfig.build.json",
    "clean": "rm -rf ./dist",
    "gen-flow-defs": "node ../../generate-flow.js",
    "rebuild": "npm run clean && npm run build && npm run gen-flow-defs",
    "create-link": "npm run rebuild && npm link",
    "pack-tar:dry": "npm run rebuild && npm pack --dry-run",
    "pack-tar": "npm run rebuild && npm pack",
    "publish:beta": "npm publish --tag beta --access public",
    "publish:prod": "npm publish --access public",
    "release": "npm run rebuild && npm publish --scope=emurgo --access public"
  },
  "author": "EMURGO",
  "license": "MIT",
  "devDependencies": {
    "@types/mocha": "^9.1.1",
    "mocha": "^10.0.0",
    "@types/chai": "^4.2.21",
    "@types/node": "^16.10.2",
    "@types/sinon": "10.0.2",
    "chai": "^4.3.4",
    "prettier": "^2.4.1",
    "sinon": "^11.1.2",
    "ts-mocha": "^10.0.0",
    "ts-node": "^10.9.1",
    "ts-sinon": "^2.0.2",
    "typescript": "^4.4.3"
  }
}
